# Tianditu (天地图) API Key
# Register at: https://console.tianditu.gov.cn/
# 1. Create account (personal developer — free, instant approval)
# 2. Create new application → type: "浏览器" (browser)
# 3. Copy the generated key here
VITE_TIANDITU_KEY=your_tianditu_key_here

# Dashscope API Key (for Tongyi Qwen-VL image recognition)
# Register at: https://dashscope.console.aliyun.com/
# 1. Create Alibaba Cloud account (free tier available)
# 2. Enable Model Studio / Dashscope service
# 3. Generate API key from the console
# Used by: Scan & Discover feature (筑览识图)
# Model: qwen-vl-max
# Cost: ~$0.001 per image identification
VITE_DASHSCOPE_KEY=your_dashscope_key_here
